# Application settings
APP_NAME="Text2SQL Backend"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development

# Server settings
HOST=0.0.0.0
PORT=8000
RELOAD=false
WORKERS=1

# Logging settings
LOG_LEVEL=INFO
LOG_SERIALIZE=false
LOG_DIAGNOSE=false

# CORS settings
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# OpenAPI settings
OPENAPI_ENABLED=true
OPENAPI_TITLE="Text2SQL API"
OPENAPI_VERSION="1.0.0"
OPENAPI_PATH="/schema"

# API settings
API_PREFIX=/api
API_TIMEOUT=30

# Database settings
USERNAME=your_db_username
PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306
DATABASE=your_database_name
DATABASE_ECHO=false

# LLM Provider Configuration
# Choose one: oci, openai, anthropic, ollama
LLM_PROVIDER=oci
MODEL_ID=cohere.command-r-plus

# Temperature settings
TEMPERATURE_CLIENT=0.0
MAX_TOKENS_CLIENT=4096
TEMPERATURE_AGENT=0.0
MAX_TOKENS_AGENT=16000

# OCI Generative AI Settings (when LLM_PROVIDER=oci)
COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-id
SERVICE_ENDPOINT=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com
AUTH_FILE_LOCATION=../.oci/config
AUTH_PROFILE=DEFAULT
AUTH_TYPE=API_KEY

# OpenAI Settings (when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1  # Optional

# Anthropic Settings (when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Ollama Settings (when LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# File export settings
CSV_EXPORT_PATH=./tmp/csv
# CSV_DOWNLOAD_BASE_URL: Use http://localhost:8000/files/csv for local development
# or your production domain for deployed environments
CSV_DOWNLOAD_BASE_URL=http://localhost:8000/files/csv